<?xml version="1.0" encoding="utf-8"?>
<!--
  Pinned trusted-signer config consumed by Invoke-DotnetToolAcquisition.ps1
  when calling `dotnet nuget verify` (with the verify-all switch)
  against a prefetched .nupkg.

  The single <repository> entry below holds the nuget.org repository
  countersigning certificate fingerprints. Every package served by
  nuget.org carries this countersignature (problem.md, decision 2), so
  one pinned entry gives uniform "served by nuget.org, untampered"
  coverage across all tools the acquirer fetches. Multiple
  <certificate> children are listed so packages signed before the
  cert rotation still verify alongside packages signed after it.

  Fingerprint source:
    https://learn.microsoft.com/nuget/reference/signed-packages-reference
  Recorded: 2026-05-27 by the feature-43 implementation.

  Current entries:
    1F4B311D9ACC115C8DC8018B5A49E00FCE6DA8E2855F9F014CA6F34570BC482D
        rotation-current cert. Valid 2024-02-23 through 2027-05-19.
        Active signer observed during feature-43 E2E.
    0E5F38F57DC1BCC806D8494F4F90FBCEDD988B46760709CBEEC6F4219AA6157D
        previous cert. Kept for packages countersigned before the
        rotation so the verifier accepts them without a fresh
        repo-resign.

  If Microsoft rotates the cert, `dotnet nuget verify` will start
  failing for fresh cache misses; add the new fingerprint here and
  bump the recorded date. Cache hits keep working because they
  short-circuit before the verifier runs.
-->
<configuration>
  <trustedSigners>
    <repository name="nuget.org"
                serviceIndex="https://api.nuget.org/v3/index.json">
      <certificate fingerprint="1F4B311D9ACC115C8DC8018B5A49E00FCE6DA8E2855F9F014CA6F34570BC482D"
                   hashAlgorithm="SHA256"
                   allowUntrustedRoot="false" />
      <certificate fingerprint="0E5F38F57DC1BCC806D8494F4F90FBCEDD988B46760709CBEEC6F4219AA6157D"
                   hashAlgorithm="SHA256"
                   allowUntrustedRoot="false" />
      <owners>nuget;Microsoft</owners>
    </repository>
  </trustedSigners>
</configuration>
